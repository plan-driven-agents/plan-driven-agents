{
  "name": "plan-driven-agents",
  "version": "0.1.0",
  "description": "Plan-driven agents — explicit, verifiable work plans for AI coding agents.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    ".claude-plugin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22",
    "bun": ">=1.3.14"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plan-driven-agents/plan-driven-agents.git"
  },
  "bugs": {
    "url": "https://github.com/plan-driven-agents/plan-driven-agents/issues"
  },
  "homepage": "https://github.com/plan-driven-agents/plan-driven-agents#readme",
  "license": "MIT",
  "keywords": [
    "agents",
    "plan-driven",
    "ai-agents",
    "tdd",
    "adr",
    "opencode",
    "claude-code",
    "plugin"
  ],
  "scripts": {
    "generate": "bun run src/generators/claude-plugin.ts",
    "build": "bun run generate && tsc",
    "e2e": "bun test tests/e2e",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "node --eval \"const { existsSync } = require('node:fs'); if (existsSync('.git')) { require('node:child_process').execFileSync('bunx', ['husky'], { stdio: 'inherit' }); }\"",
    "prepublishOnly": "bun run generate && bun run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.15.6"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@types/node": "^22.0.0",
    "gray-matter": "^4.0.3",
    "husky": "latest",
    "typescript": "latest"
  }
}
